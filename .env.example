## Example environment variables for Supabase integration and app config
# Supabase project settings (do NOT commit your real keys)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# App secrets
SECRET_KEY=replace-this-with-a-secret
REFRESH_SECRET=
ADMIN_SECRET=

# Optional: football-data.org API key
FOOTBALL_DATA_API_KEY=
